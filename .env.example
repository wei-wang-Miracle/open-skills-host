# ============================================
# OpenAI 兼容 API 配置
# ============================================
# 你的 API Key（支持 OpenAI、Moonshot、DeepSeek、Qwen 等）
OPENAI_API_KEY=sk-your-api-key-here

# API 基础地址
# OpenAI: https://api.openai.com/v1
# Moonshot: https://api.moonshot.cn/v1
# DeepSeek: https://api.deepseek.com/v1
OPENAI_API_BASE=https://api.moonshot.cn/v1

# ============================================
# LLM 模型配置
# ============================================
# 模型名称
LLM_MODEL=kimi-k2-0711-preview

# 温度参数（0-2，越低越确定，越高越创意）
LLM_TEMPERATURE=0.1

# ============================================
# 技能目录
# ============================================
# 技能存放目录，支持以下格式：
# - 绝对路径：/home/user/skills
# - 相对路径：./skills（以项目根目录为基准）
# - 家目录：~/skills
SKILLS_DIR=~/my-skills

# ============================================
# 技能产出物输出目录
# ============================================
# 技能执行产生的文件将保存到此目录
# 脚本执行时通过 SKILLS_OUTPUT_DIR 环境变量注入
# 支持绝对路径、相对路径、家目录
SKILLS_OUTPUT_DIR=~/outputs

# ============================================
# CDN 配置（可选）
# ============================================
# 产出文件上传的 CDN 地址，用于 HTTP API 模式返回下载链接
# 如果不配置，API 响应中将不包含 download_url
CDN_UPLOAD_URL=
